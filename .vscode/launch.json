{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "npm: start",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "start"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal"
    },
    {
      "name": "ngrok http 3000",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["ngrok", "http", "3000"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal"
    },
    {
      "name": "Run all test_suite files",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/test_suite/run_test_suite.js",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal"
    },
    {
      "name": "Run current test file",
      "type": "node",
      "request": "launch",
      "program": "${file}",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal"
    }
  ],
  "compounds": [
    {
      "name": "Run npm start + ngrok",
      "configurations": ["npm: start", "ngrok http 3000"]
    }
  ]
}
